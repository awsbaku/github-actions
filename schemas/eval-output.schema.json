{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hackathon PR Evaluation Result",
  "type": "object",
  "required": [
    "team",
    "repo",
    "pr_number",
    "timestamp",
    "evaluation_version",
    "dimensions",
    "anti_gaming",
    "overall_score",
    "flags",
    "summary"
  ],
  "properties": {
    "team": {
      "type": "string",
      "description": "Team identifier, e.g. 'team-alpha'"
    },
    "repo": {
      "type": "string",
      "description": "Full GitHub repo slug, e.g. 'awsbaku/team-alpha'"
    },
    "pr_number": {
      "type": "integer"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "evaluation_version": {
      "type": "string",
      "description": "Rubric version, e.g. 'v1.0'"
    },
    "project_type": {
      "type": "string",
      "description": "Project classification defined by the hackathon theme prompt (e.g. 'agentic_workflow', 'rag_application')"
    },
    "dimensions": {
      "type": "object",
      "required": [
        "functional_value",
        "aws_integration",
        "innovation",
        "code_quality",
        "documentation"
      ],
      "properties": {
        "functional_value": { "$ref": "#/$defs/dimension_score" },
        "aws_integration": { "$ref": "#/$defs/dimension_score" },
        "innovation": { "$ref": "#/$defs/dimension_score" },
        "code_quality": { "$ref": "#/$defs/dimension_score" },
        "documentation": { "$ref": "#/$defs/dimension_score" }
      }
    },
    "anti_gaming": {
      "type": "object",
      "required": ["penalty_total"],
      "properties": {
        "penalty_total": {
          "type": "number",
          "minimum": 0,
          "description": "Total score penalty applied (0.0 = no penalty)"
        },
        "checks_triggered": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["check_name", "triggered"],
            "properties": {
              "check_name": { "type": "string" },
              "triggered": { "type": "boolean" },
              "detail": { "type": "string" },
              "penalty_applied": { "type": "number" }
            }
          },
          "description": "List of anti-gaming checks and their results"
        }
      }
    },
    "overall_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Weighted average minus penalties, rounded to 1 decimal"
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "trivial_commit",
          "whitespace_padding",
          "boilerplate_dump",
          "code_dump",
          "low_commit_quality",
          "suspected_generated_dump",
          "hardcoded_credentials",
          "prompt_injection_attempt",
          "pr_recycling",
          "no_aws_services_found",
          "incomplete_implementation",
          "exceptional_work"
        ]
      }
    },
    "leaderboard_contribution": {
      "type": "object",
      "properties": {
        "delta_score": {
          "type": ["number", "null"],
          "description": "Score change from previous evaluation (null if first eval)"
        },
        "time_decay_factor": {
          "type": "number",
          "description": "Multiplier based on submission timing (1.0 = full credit)"
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "2-4 sentence human-readable summary"
    },
    "reviewer_notes": {
      "type": ["string", "null"],
      "description": "Anything requiring human organizer attention"
    }
  },
  "$defs": {
    "dimension_score": {
      "type": "object",
      "required": ["score", "reasoning", "evidence"],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "reasoning": {
          "type": "string",
          "description": "1-3 sentence justification"
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Specific file:observation references"
        }
      }
    }
  }
}
